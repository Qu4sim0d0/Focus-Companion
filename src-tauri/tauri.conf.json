{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Companion",
  "version": "0.1.0",
  "identifier": "dev.local.focus-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Companion",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "13.0",
      "files": {
        "Info.plist": "./Info.plist"
      }
    }
  }
}
